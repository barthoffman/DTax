# SMTP voor de e-mail-OTP (Gmail). Kopieer dit bestand naar .env en vul in.
# .env staat in .gitignore — je wachtwoord komt NOOIT in git.
#
# Gmail vereist: 2-staps-verificatie AAN + een App-wachtwoord
#   Google-account -> Beveiliging -> App-wachtwoorden -> nieuw wachtwoord genereren.
#   Gebruik dat 16-tekens app-wachtwoord hieronder (NIET je gewone wachtwoord).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bart.hoffman@gmail.com
SMTP_PASS=je-16-tekens-app-wachtwoord
SMTP_FROM=bart.hoffman@gmail.com

# Admin: mag altijd inloggen + beheert de allowlist (default = bart.hoffman@gmail.com)
ADMIN_EMAIL=bart.hoffman@gmail.com
